# .env.example
# ============
# Docker Compose automatically reads a file named `.env` in this folder and uses
# it for ${VARIABLE} substitution in docker-compose.yml. Copy this file to `.env`
# and paste your Kaggle API credentials to enable the WM-811K auto-download.
#
#   cp .env.example .env
#   # then edit .env with your real values
#
# `.env` is gitignored, so your real key is never committed.
#
# Where to get these: kaggle.com -> Account -> "Create New API Token" downloads a
# kaggle.json that contains {"username": "...", "key": "..."}. Put those here.
#
# Everything in the suite works WITHOUT these — you simply won't be able to
# auto-download WM-811K; use the dashboard's "Register an existing LSWMD.pkl"
# path (or the register_wm811k tool) instead.

KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
